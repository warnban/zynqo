# Скопируйте в server/.env и заполните

# Режим (production на сервере)
# NODE_ENV=production
# HOST=0.0.0.0
# SERVE_STATIC=true
# STATIC_DIR=../dist
# DATA_DIR=./data
# DB_PATH=./data/zynqo.db
# CORS_ORIGINS=https://zynqo.ru

# Ключ AI Tunnel (https://aitunnel.ru). Если пусто — генерации работают в ДЕМО-режиме.
AITUNNEL_API_KEY=
AITUNNEL_BASE_URL=https://api.aitunnel.ru/v1

# Секрет для подписи JWT (обязательно смените на длинную случайную строку)
JWT_SECRET=change-me-to-a-long-random-string

# Порт бэкенда
PORT=8787

# Первый администратор (создаётся при старте, если ещё нет)
ADMIN_EMAIL=admin@zynqo.local

# SMTP для подтверждения e-mail при регистрации (6-значный код)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@zynqo.ru
ADMIN_PASSWORD=admin12345

# Адрес сайта (HTTPS на проде). Для CORS и редиректов VK.
APP_URL=http://localhost:5173

# Вход через VK ID (https://id.vk.com → Мои приложения). Если пусто — кнопка VK скрыта.
VK_CLIENT_ID=
# Доверенный Redirect URI (должен совпадать с указанным в настройках VK-приложения)
VK_REDIRECT_URI=http://localhost:8787/api/auth/vk/callback
# Защищённый ключ (только для конфиденциальных приложений; для PKCE не обязателен)
VK_SERVICE_TOKEN=
VK_SCOPE=email phone
