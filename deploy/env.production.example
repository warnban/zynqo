# Скопируйте в server/.env на сервере

NODE_ENV=production
PORT=8787
HOST=0.0.0.0

# Публичный URL сайта (HTTPS!)
APP_URL=https://zynqo.ru
CORS_ORIGINS=https://zynqo.ru,https://www.zynqo.ru

# Обязательно — случайная строка 48+ символов
JWT_SECRET=

# AI Tunnel
AITUNNEL_API_KEY=
AITUNNEL_BASE_URL=https://api.aitunnel.ru/v1

# Админ (смените пароль!)
ADMIN_EMAIL=admin@zynqo.ru
ADMIN_PASSWORD=

# SMTP (регистрация с кодом)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@zynqo.ru
SMTP_PASS=
SMTP_FROM=noreply@zynqo.ru

# VK ID (опционально)
VK_CLIENT_ID=
VK_REDIRECT_URI=https://zynqo.ru/api/auth/vk/callback
VK_SERVICE_TOKEN=
VK_SCOPE=email phone

# Для docker-compose + Caddy
DOMAIN=zynqo.ru
ACME_EMAIL=support@zynqo.ru
